# Server Environment Variables
PORT=3001

# Flotiq Headless CMS API Key (Read-Write)
FLOTIQ_API_KEY=your_flotiq_rw_api_key_here

# Daily.co API Key (for video rooms & recordings)
DAILY_API_KEY=your_daily_co_api_key_here

# Clerk Secret Key (for securing backend endpoints)
CLERK_SECRET_KEY=your_clerk_secret_key_here
